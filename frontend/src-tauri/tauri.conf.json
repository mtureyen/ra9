{
  "$schema": "https://raw.githubusercontent.com/nickelc/tauri-v2-schema/main/tauri.conf.json",
  "productName": "ra9",
  "version": "0.1.0",
  "identifier": "com.ra9.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ra9 — Ryo",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000; style-src 'self' 'unsafe-inline'"
    }
  }
}
